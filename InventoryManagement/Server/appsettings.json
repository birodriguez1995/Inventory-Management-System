{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=inventory.db"
  },
  "JwtSettings": {
    "Secret": "inventory-super-secret-key-change-in-production-32chars!!",
    "Issuer": "InventoryManagement",
    "Audience": "InventoryManagement",
    "ExpiryHours": "8"
  },
  "LowStockAlert": {
    "Threshold": 10,
    "IntervalMinutes": 5
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
